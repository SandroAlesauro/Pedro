<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="64dp"
        android:paddingBottom="40dp">

        <!-- Onboarding Psicologico (Brutale) -->
        <TextView
            android:id="@+id/brutal_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_card_light"
            android:padding="20dp"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="24dp"
            android:lineSpacingExtra="4dp"
            android:gravity="center" />

        <!-- App selection header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/blocked_apps"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.2"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/btn_manage_apps"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/choose_apps_btn"
            android:background="@drawable/bg_option"
            android:textColor="@color/accent_cyan"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:fontFamily="sans-serif"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/app_list_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp" />

        <!-- Localisation config -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/localization"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.2"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/btn_language"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_glass_card"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/quiz_language"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/val_language"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ITALIANO"
                android:textColor="@color/accent_cyan"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Protocol config -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/unlock_protocol"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.2"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="4dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:id="@+id/btn_topic"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/topic"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/val_topic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMPUTER SCIENCE"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#15FFFFFF" android:layout_marginStart="16dp" />

            <LinearLayout
                android:id="@+id/btn_diff"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/difficulty"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/val_diff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MEDIO"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#15FFFFFF" android:layout_marginStart="16dp" />

            <LinearLayout
                android:id="@+id/btn_duration"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/window_duration"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />
                <TextView
                    android:id="@+id/val_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10 MIN"
                    android:textColor="@color/accent_cyan"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_accessibility"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_glass_card"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/accessibility_service"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/val_accessibility_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/connected"
                android:textColor="@color/accent_cyan"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Donate section -->
        <LinearLayout
            android:id="@+id/btn_donate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/support_project"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/donate_desc"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/made_with_love"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:paddingBottom="20dp"
            android:fontFamily="monospace" />

    </LinearLayout>
</ScrollView>
