<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="32dp">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/quiz_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/quiz_app_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="INSTAGRAM"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/quiz_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/3"
                android:textColor="@color/accent_cyan"
                android:textSize="16sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Interstitial Card Containers (Nuova Feature: Schermata di Riflessione) -->
        <LinearLayout
            android:id="@+id/interstitial_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/quiz_header"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="24dp"
            android:elevation="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/interstitial_title"
                android:textColor="@color/accent_cyan"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="monospace"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/interstitial_desc"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:gravity="center"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="32dp" />

            <!-- Btn: Torna Indietro -->
            <TextView
                android:id="@+id/btn_interstitial_home"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_go_home"
                android:background="@drawable/bg_option"
                android:backgroundTint="@color/accent_cyan"
                android:textColor="@color/bg_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="12dp"
                android:clickable="true"
                android:focusable="true" />
            
            <!-- Btn: Procedi al Quiz -->
            <TextView
                android:id="@+id/btn_interstitial_quiz"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_do_quiz"
                android:background="@drawable/bg_option"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:gravity="center"
                android:fontFamily="sans-serif"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Main Card Container -->
        <LinearLayout
            android:id="@+id/quiz_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/quiz_header"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="24dp"
            android:elevation="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/quiz_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quale numero viene dopo il 14?"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:gravity="center"
                android:fontFamily="monospace"
                android:layout_marginBottom="32dp" />

            <LinearLayout
                android:id="@+id/options_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/quiz_opt_0"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="15"
                    android:background="@drawable/bg_option"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/quiz_opt_1"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="13"
                    android:background="@drawable/bg_option"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/quiz_opt_2"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="16"
                    android:background="@drawable/bg_option"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/quiz_opt_3"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="12"
                    android:background="@drawable/bg_option"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- Error Msg -->
            <TextView
                android:id="@+id/quiz_error_msg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ERRORE: COOLDOWN 2 MIN"
                android:textColor="@color/accent_red"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Footer Action -->
        <TextView
            android:id="@+id/quiz_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/quiz_card"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:padding="20dp"
            android:text="TORNA ALLA HOME"
            android:textColor="@color/text_dim"
            android:textSize="12sp"
            android:letterSpacing="0.05"
            android:fontFamily="sans-serif" />

    </RelativeLayout>
</ScrollView>
