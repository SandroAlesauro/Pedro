<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="64dp"
        android:paddingBottom="40dp">

        <!-- Reality Check Dashboard -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reality_check"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.2"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <!-- Prima riga di KPI -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_glass_card"
                    android:padding="16dp"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/unlocks"
                        android:textColor="@color/text_dim"
                        android:textSize="8sp" />
                    <TextView
                        android:id="@+id/kpi_unlocks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_glass_card"
                    android:padding="16dp"
                    android:layout_marginStart="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/resisted"
                        android:textColor="@color/text_dim"
                        android:textSize="8sp" />
                    <TextView
                        android:id="@+id/kpi_resisted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/accent_cyan"
                        android:textSize="18sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

            <!-- Seconda riga di KPI -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_glass_card"
                    android:padding="16dp"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/social_day"
                        android:textColor="@color/text_dim"
                        android:textSize="8sp" />
                    <TextView
                        android:id="@+id/kpi_usage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_glass_card"
                    android:padding="16dp"
                    android:layout_marginStart="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lost_year"
                        android:textColor="@color/text_dim"
                        android:textSize="8sp" />
                    <TextView
                        android:id="@+id/kpi_projection"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/accent_red"
                        android:textSize="18sp"
                        android:fontFamily="monospace" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- Focus Mode -->
        <LinearLayout
            android:id="@+id/focus_mode_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/focus_mode_title"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/focus_timer_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25:00"
                    android:textColor="@color/accent_cyan"
                    android:textSize="18sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_focus_start"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:text="@string/focus_start"
                android:background="@drawable/bg_option"
                android:backgroundTint="@color/accent_cyan"
                android:textColor="@color/bg_dark"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_focus_stop"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:text="@string/focus_stop"
                android:background="@drawable/bg_option"
                android:textColor="@color/accent_red"
                android:textSize="12sp"
                android:gravity="center"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Insight settimanale -->
        <TextView
            android:id="@+id/weekly_insight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:padding="14dp"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:gravity="center"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- Condividi Stats -->
        <TextView
            android:id="@+id/btn_share_stats"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="@string/share_stats"
            android:background="@drawable/bg_option"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Grafico settimanale -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/weekly_chart_title"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp" />

        <com.pedro.app.WeeklyChartView
            android:id="@+id/weekly_chart"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginBottom="8dp" />

        <!-- Indicatore limite giornaliero -->
        <LinearLayout
            android:id="@+id/daily_limit_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/daily_limit_label"
                    android:textColor="@color/text_dim"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.2" />
                <TextView
                    android:id="@+id/daily_limit_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0m / 0m"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="#30FFFFFF">
                <View
                    android:id="@+id/daily_limit_bar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@color/text_primary" />
            </FrameLayout>
        </LinearLayout>

        <!-- List Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/active"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.2"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp" />

        <!-- App list container -->
        <LinearLayout
            android:id="@+id/app_list_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Footer Credits -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/made_with_love"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:paddingTop="40dp"
            android:paddingBottom="20dp"
            android:fontFamily="monospace" />

    </LinearLayout>
</ScrollView>
